---
import Layout from '../layouts/Layout.astro';

// Same-origin Vercel Edge proxies that hold the STATS_TOKEN server-side
// and forward to the ct-analytics Worker.
const ENDPOINTS = {
  stats: '/api/stats',
  live: '/api/stats-live',
  history: '/api/stats-history',
};
const HISTORY_DAYS = 30;
---

<Layout title="Stats — ClaudeTerminal" description="Internal telemetry dashboard.">
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow, noarchive" />
  </Fragment>

  <main class="min-h-screen pt-10 pb-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="flex flex-wrap items-end justify-between gap-4 mb-8">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="inline-flex items-center gap-2 px-2.5 py-1 rounded-full bg-[#d97757]/15 border border-[#d97757]/30 text-[#d97757] text-xs font-mono">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#d97757] opacity-60"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-[#d97757]"></span>
              </span>
              LIVE
            </span>
            <span class="text-xs text-slate-500 font-mono">/stat</span>
          </div>
          <h1 class="text-3xl sm:text-4xl font-bold text-white">Telemetry</h1>
          <p class="text-slate-400 text-sm mt-1">Real-time stats from ClaudeTerminal installations.</p>
        </div>

        <div class="flex items-center gap-3">
          <div id="status-pill" class="text-xs font-mono px-3 py-1.5 rounded-md surface text-slate-400">
            connecting…
          </div>
          <button
            id="refresh-btn"
            type="button"
            class="text-xs font-mono px-3 py-1.5 rounded-md bg-[#d97757]/20 hover:bg-[#d97757]/30 border border-[#d97757]/40 text-[#d97757] transition-colors"
          >
            refresh
          </button>
        </div>
      </div>

      <!-- Live now banner -->
      <div class="surface rounded-xl p-5 mb-6 border border-[#d97757]/20">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div class="flex items-baseline gap-4">
            <div>
              <div class="text-xs font-mono uppercase tracking-wider text-slate-500 mb-1">Active Now</div>
              <div class="flex items-baseline gap-2">
                <span id="kpi-active-now" class="text-4xl font-bold text-[#d97757] tabular-nums">—</span>
                <span class="text-xs font-mono text-slate-500">in last <span id="kpi-active-window">15</span> min</span>
              </div>
            </div>
          </div>
          <div class="flex flex-wrap gap-x-6 gap-y-1 text-xs font-mono text-slate-400">
            <span>versions: <span id="kpi-active-versions" class="text-slate-200">—</span></span>
            <span>os: <span id="kpi-active-os" class="text-slate-200">—</span></span>
            <span>countries: <span id="kpi-active-countries" class="text-slate-200">—</span></span>
          </div>
        </div>
      </div>

      <!-- KPI cards -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="surface rounded-xl p-5">
          <div class="text-xs font-mono uppercase tracking-wider text-slate-500 mb-2">Date</div>
          <div id="kpi-date" class="text-2xl font-bold text-white font-mono tabular-nums">—</div>
        </div>
        <div class="surface rounded-xl p-5">
          <div class="text-xs font-mono uppercase tracking-wider text-slate-500 mb-2">Daily Active Users</div>
          <div id="kpi-dau" class="text-3xl font-bold text-[#d97757] tabular-nums">—</div>
        </div>
        <div class="surface rounded-xl p-5">
          <div class="text-xs font-mono uppercase tracking-wider text-slate-500 mb-2">Heartbeats Today</div>
          <div id="kpi-hb" class="text-3xl font-bold text-white tabular-nums">—</div>
        </div>
        <div class="surface rounded-xl p-5">
          <div class="text-xs font-mono uppercase tracking-wider text-slate-500 mb-2">Update Checks Today</div>
          <div id="kpi-uc" class="text-3xl font-bold text-white tabular-nums">—</div>
        </div>
      </div>

      <!-- Total installs banner -->
      <div class="surface rounded-xl p-5 mb-8 flex items-center justify-between flex-wrap gap-4">
        <div>
          <div class="text-xs font-mono uppercase tracking-wider text-slate-500 mb-1">Total Installations</div>
          <div id="kpi-installs" class="text-4xl font-bold text-white tabular-nums">—</div>
        </div>
        <div class="text-right">
          <div class="text-xs font-mono uppercase tracking-wider text-slate-500 mb-1">Last Refreshed</div>
          <div id="last-updated" class="text-sm font-mono text-slate-300">—</div>
        </div>
      </div>

      <!-- Time-series charts -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
        <section class="surface rounded-xl p-5">
          <div class="flex items-center justify-between mb-1">
            <h2 class="text-sm font-mono uppercase tracking-wider text-slate-400">DAU · last 30 days</h2>
            <span id="chart-dau-peak" class="text-xs font-mono text-slate-600">peak —</span>
          </div>
          <p class="text-xs text-slate-500 mb-3">Unique installations sending a heartbeat per UTC day.</p>
          <svg id="chart-dau" viewBox="0 0 1000 200" preserveAspectRatio="none" class="w-full h-32 block"></svg>
          <div class="flex items-center justify-between text-[10px] font-mono text-slate-600 mt-2">
            <span id="chart-dau-from">—</span>
            <span id="chart-dau-to">—</span>
          </div>
        </section>

        <section class="surface rounded-xl p-5">
          <div class="flex items-center justify-between mb-1">
            <h2 class="text-sm font-mono uppercase tracking-wider text-slate-400">Heartbeats · last 30 days</h2>
            <span id="chart-hb-peak" class="text-xs font-mono text-slate-600">peak —</span>
          </div>
          <p class="text-xs text-slate-500 mb-3">Total heartbeat pings ingested per UTC day.</p>
          <svg id="chart-hb" viewBox="0 0 1000 200" preserveAspectRatio="none" class="w-full h-32 block"></svg>
          <div class="flex items-center justify-between text-[10px] font-mono text-slate-600 mt-2">
            <span id="chart-hb-from">—</span>
            <span id="chart-hb-to">—</span>
          </div>
        </section>
      </div>

      <!-- Version adoption stacked area -->
      <section class="surface rounded-xl p-5 mb-8">
        <div class="flex items-center justify-between mb-1">
          <h2 class="text-sm font-mono uppercase tracking-wider text-slate-400">Version adoption · last 30 days</h2>
          <span id="chart-version-buckets" class="text-xs font-mono text-slate-600">0 versions</span>
        </div>
        <p class="text-xs text-slate-500 mb-3">Stacked share of heartbeats by app version per day. Newer versions appear at the bottom of the stack.</p>
        <svg id="chart-versions" viewBox="0 0 1000 220" preserveAspectRatio="none" class="w-full h-40 block"></svg>
        <div id="chart-versions-legend" class="flex flex-wrap gap-x-4 gap-y-1.5 text-xs font-mono mt-3"></div>
        <div class="flex items-center justify-between text-[10px] font-mono text-slate-600 mt-2">
          <span id="chart-versions-from">—</span>
          <span id="chart-versions-to">—</span>
        </div>
      </section>

      <!-- Today's distributions -->
      <h2 class="text-sm font-mono uppercase tracking-wider text-slate-400 mb-4">Today's distributions</h2>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <section class="surface rounded-xl p-5">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-sm font-mono uppercase tracking-wider text-slate-400">Versions</h3>
            <span id="count-versions" class="text-xs font-mono text-slate-600">0</span>
          </div>
          <div id="dist-versions" class="space-y-2.5"></div>
        </section>

        <section class="surface rounded-xl p-5">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-sm font-mono uppercase tracking-wider text-slate-400">Operating Systems</h3>
            <span id="count-os" class="text-xs font-mono text-slate-600">0</span>
          </div>
          <div id="dist-os" class="space-y-2.5"></div>
        </section>

        <section class="surface rounded-xl p-5">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-sm font-mono uppercase tracking-wider text-slate-400">Countries</h3>
            <span id="count-countries" class="text-xs font-mono text-slate-600">0</span>
          </div>
          <div id="dist-countries" class="space-y-2.5"></div>
        </section>
      </div>

      <!-- Raw payload (debug) -->
      <details class="mt-8 surface rounded-xl p-4">
        <summary class="text-xs font-mono uppercase tracking-wider text-slate-500 cursor-pointer select-none hover:text-slate-300">Raw payload</summary>
        <pre id="raw-payload" class="mt-3 text-xs text-slate-400 font-mono overflow-x-auto whitespace-pre-wrap break-words">—</pre>
      </details>

      <p class="mt-8 text-center text-xs text-slate-600 font-mono">
        live data refreshes every 15s · history refreshes every 5 min
      </p>
    </div>
  </main>

  <script define:vars={{ ENDPOINTS, HISTORY_DAYS }}>
  const $ = (id) => document.getElementById(id);
  const LIVE_POLL_MS = 15_000;
  const HISTORY_POLL_MS = 5 * 60_000;

  // Chart series colors. First (lime) is the primary brand color and the
  // newest/biggest series; subsequent slots cover up to ~6 versions before
  // wrapping. Order matters — newest version sorts to the bottom of the stack
  // (rendered first, painted underneath the older ones above it).
  const SERIES_COLORS = ['#d97757', '#60a5fa', '#f472b6', '#fbbf24', '#a78bfa', '#34d399'];

  // ISO 3166-1 alpha-2 → display name (partial; falls back to the code itself).
  const COUNTRY_NAMES = {
    US: 'United States', IL: 'Israel', GB: 'United Kingdom', DE: 'Germany',
    FR: 'France', CA: 'Canada', AU: 'Australia', JP: 'Japan', CN: 'China',
    IN: 'India', BR: 'Brazil', RU: 'Russia', NL: 'Netherlands', ES: 'Spain',
    IT: 'Italy', SE: 'Sweden', NO: 'Norway', FI: 'Finland', DK: 'Denmark',
    PL: 'Poland', UA: 'Ukraine', MX: 'Mexico', AR: 'Argentina', ZA: 'South Africa',
    KR: 'South Korea', TR: 'Turkey', SG: 'Singapore', CH: 'Switzerland',
    AT: 'Austria', BE: 'Belgium', IE: 'Ireland', PT: 'Portugal', GR: 'Greece',
    CZ: 'Czechia', RO: 'Romania', HU: 'Hungary', NZ: 'New Zealand',
    HK: 'Hong Kong', TW: 'Taiwan', TH: 'Thailand', VN: 'Vietnam', ID: 'Indonesia',
    PH: 'Philippines', MY: 'Malaysia', AE: 'UAE', SA: 'Saudi Arabia',
    EG: 'Egypt', NG: 'Nigeria', KE: 'Kenya', CL: 'Chile', CO: 'Colombia',
  };

  function countryFlag(code) {
    if (typeof code !== 'string' || code.length !== 2) return '🏳️';
    const cc = code.toUpperCase();
    if (!/^[A-Z]{2}$/.test(cc)) return '🏳️';
    const base = 127397;
    return String.fromCodePoint(base + cc.charCodeAt(0), base + cc.charCodeAt(1));
  }

  function osIcon(os) {
    const key = String(os || '').toLowerCase();
    if (key.includes('win')) return '🪟';
    if (key.includes('mac') || key.includes('darwin') || key.includes('osx')) return '🍎';
    if (key.includes('linux')) return '🐧';
    if (key.includes('bsd')) return '😈';
    return '💻';
  }

  function osLabel(os) {
    const key = String(os || '').toLowerCase();
    if (key.includes('win')) return 'Windows';
    if (key.includes('darwin') || key.includes('mac')) return 'macOS';
    if (key.includes('linux')) return 'Linux';
    return String(os || 'Unknown');
  }

  function formatNumber(n) {
    if (typeof n !== 'number' || !Number.isFinite(n)) return '—';
    return n.toLocaleString('en-US');
  }

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    }[c]));
  }

  function distinctCount(obj) {
    if (!obj || typeof obj !== 'object') return 0;
    return Object.values(obj).filter((v) => typeof v === 'number' && v > 0).length;
  }

  // Sort versions semver-style descending so the newest appears first.
  function compareVersionDesc(a, b) {
    const pa = a.split('.').map((n) => parseInt(n, 10) || 0);
    const pb = b.split('.').map((n) => parseInt(n, 10) || 0);
    for (let i = 0; i < Math.max(pa.length, pb.length); i++) {
      const da = pa[i] ?? 0;
      const db = pb[i] ?? 0;
      if (da !== db) return db - da;
    }
    return 0;
  }

  // ── Chart renderers ────────────────────────────────────────────────────────

  function renderLineArea(svgId, series, color, peakElId, fromElId, toElId) {
    const svg = $(svgId);
    if (!svg) return;
    if (!Array.isArray(series) || series.length === 0) {
      svg.innerHTML = '<text x="500" y="100" text-anchor="middle" fill="#475569" font-family="monospace" font-size="14">No data yet</text>';
      if (peakElId) $(peakElId).textContent = 'peak —';
      return;
    }
    const W = 1000, H = 200;
    const max = Math.max(...series.map((p) => p.value || 0), 1);
    const n = series.length;
    const pts = series.map((p, i) => {
      const x = n === 1 ? W / 2 : (i / (n - 1)) * W;
      const y = H - ((p.value || 0) / max) * (H - 8) - 4; // 4px top/bottom padding
      return { x, y, value: p.value || 0, date: p.date };
    });
    const linePath = pts.map((p, i) => `${i ? 'L' : 'M'}${p.x.toFixed(2)},${p.y.toFixed(2)}`).join('');
    const areaPath = `${linePath} L${W},${H} L0,${H} Z`;
    const dots = pts
      .map((p) => `<circle cx="${p.x.toFixed(2)}" cy="${p.y.toFixed(2)}" r="2.5" fill="${color}" opacity="0.9"><title>${p.date}: ${formatNumber(p.value)}</title></circle>`)
      .join('');
    svg.innerHTML = `
      <path d="${areaPath}" fill="${color}" fill-opacity="0.12" />
      <path d="${linePath}" fill="none" stroke="${color}" stroke-width="2" vector-effect="non-scaling-stroke" stroke-linejoin="round" stroke-linecap="round" />
      ${dots}
    `;
    if (peakElId) $(peakElId).textContent = `peak ${formatNumber(max)}`;
    if (fromElId) $(fromElId).textContent = series[0]?.date ?? '';
    if (toElId) $(toElId).textContent = series[n - 1]?.date ?? '';
  }

  function renderStackedArea(svgId, legendElId, bucketsCountElId, fromElId, toElId, series) {
    const svg = $(svgId);
    const legend = legendElId ? $(legendElId) : null;
    if (!svg) return;

    if (!Array.isArray(series) || series.length === 0) {
      svg.innerHTML = '<text x="500" y="110" text-anchor="middle" fill="#475569" font-family="monospace" font-size="14">No data yet</text>';
      if (legend) legend.innerHTML = '';
      if (bucketsCountElId) $(bucketsCountElId).textContent = '0 versions';
      return;
    }

    // Group: dates ascending, buckets sorted newest version first (so newest renders at bottom of stack).
    const dates = [...new Set(series.map((p) => p.date))].sort();
    const totalsByBucket = {};
    for (const p of series) totalsByBucket[p.bucket] = (totalsByBucket[p.bucket] || 0) + (p.value || 0);
    const buckets = Object.keys(totalsByBucket).sort(compareVersionDesc);

    const byDate = Object.fromEntries(dates.map((d) => [d, {}]));
    for (const p of series) byDate[p.date][p.bucket] = p.value || 0;

    const totalPerDate = dates.map((d) => buckets.reduce((sum, b) => sum + (byDate[d][b] || 0), 0));
    const maxTotal = Math.max(...totalPerDate, 1);

    const W = 1000, H = 220;
    const cumulative = dates.map(() => 0);
    let svgContent = '';

    buckets.forEach((bucket, bi) => {
      const color = SERIES_COLORS[bi % SERIES_COLORS.length];
      const points = dates.map((d, i) => {
        const val = byDate[d][bucket] || 0;
        const yBottom = H - (cumulative[i] / maxTotal) * (H - 4) - 2;
        cumulative[i] += val;
        const yTop = H - (cumulative[i] / maxTotal) * (H - 4) - 2;
        const x = dates.length === 1 ? W / 2 : (i / (dates.length - 1)) * W;
        return { x, yBottom, yTop };
      });
      const top = points.map((p, i) => `${i ? 'L' : 'M'}${p.x.toFixed(2)},${p.yTop.toFixed(2)}`).join('');
      const bottom = points
        .slice()
        .reverse()
        .map((p) => `L${p.x.toFixed(2)},${p.yBottom.toFixed(2)}`)
        .join('');
      svgContent += `<path d="${top}${bottom}Z" fill="${color}" fill-opacity="0.78"><title>v${bucket}: ${formatNumber(totalsByBucket[bucket])} heartbeats over ${dates.length} day(s)</title></path>`;
    });

    svg.innerHTML = svgContent;

    if (legend) {
      legend.innerHTML = buckets
        .map((b, i) => {
          const color = SERIES_COLORS[i % SERIES_COLORS.length];
          return `<span class="inline-flex items-center gap-1.5"><span class="inline-block w-2.5 h-2.5 rounded-sm" style="background:${color}"></span><span class="text-slate-300">v${escapeHtml(b)}</span><span class="text-slate-600">${formatNumber(totalsByBucket[b])}</span></span>`;
        })
        .join('');
    }
    if (bucketsCountElId) $(bucketsCountElId).textContent = `${buckets.length} version${buckets.length === 1 ? '' : 's'}`;
    if (fromElId) $(fromElId).textContent = dates[0] ?? '';
    if (toElId) $(toElId).textContent = dates[dates.length - 1] ?? '';
  }

  // ── Distribution bars (today's snapshot) ───────────────────────────────────

  function emptyState(message) {
    const el = document.createElement('div');
    el.className = 'text-sm text-slate-500 italic py-4 text-center';
    el.textContent = message;
    return el;
  }

  function errorState(message) {
    const el = document.createElement('div');
    el.className = 'text-sm text-red-400 py-4 text-center font-mono';
    el.textContent = message;
    return el;
  }

  function renderBar(label, subLabel, value, max, total) {
    const pct = total > 0 ? (value / total) * 100 : 0;
    const widthPct = max > 0 ? (value / max) * 100 : 0;

    const row = document.createElement('div');
    row.className = 'group';
    row.innerHTML = `
      <div class="flex items-baseline justify-between gap-2 mb-1">
        <span class="text-sm text-slate-200 truncate">${label}${subLabel ? `<span class="text-slate-600 ml-1.5 text-xs font-mono">${subLabel}</span>` : ''}</span>
        <span class="text-xs font-mono text-slate-400 tabular-nums flex-shrink-0">${formatNumber(value)} <span class="text-slate-600">(${pct.toFixed(1)}%)</span></span>
      </div>
      <div class="h-2 rounded-full bg-slate-800/60 overflow-hidden">
        <div class="h-full rounded-full bg-[#d97757] transition-all duration-500" style="width: ${widthPct}%"></div>
      </div>
    `;
    return row;
  }

  function renderDistribution(containerId, countId, dist, formatter) {
    const container = $(containerId);
    const countEl = $(countId);
    container.innerHTML = '';

    const entries = dist && typeof dist === 'object'
      ? Object.entries(dist).filter(([, v]) => typeof v === 'number' && v > 0)
      : [];

    countEl.textContent = entries.length.toString();

    if (entries.length === 0) {
      container.appendChild(emptyState('No data yet'));
      return;
    }

    entries.sort((a, b) => b[1] - a[1]);
    const total = entries.reduce((sum, [, v]) => sum + v, 0);
    const max = entries[0][1];

    for (const [key, value] of entries) {
      const { label, sub } = formatter(key);
      container.appendChild(renderBar(label, sub, value, max, total));
    }
  }

  // ── Status pill ────────────────────────────────────────────────────────────

  function setStatus(state, detail) {
    const pill = $('status-pill');
    pill.classList.remove('text-slate-400', 'text-emerald-300', 'text-red-400', 'text-amber-300');
    pill.classList.add(
      state === 'ok' ? 'text-emerald-300'
      : state === 'error' ? 'text-red-400'
      : state === 'loading' ? 'text-amber-300'
      : 'text-slate-400'
    );
    pill.textContent = detail;
  }

  // ── Live + today fetch ─────────────────────────────────────────────────────

  let liveInFlight = false;
  async function fetchLiveAndToday() {
    if (liveInFlight) return;
    liveInFlight = true;
    setStatus('loading', 'fetching…');
    try {
      const [statsRes, liveRes] = await Promise.all([
        fetch(ENDPOINTS.stats, { cache: 'no-store' }),
        fetch(ENDPOINTS.live, { cache: 'no-store' }),
      ]);
      if (!statsRes.ok) throw new Error(`stats HTTP ${statsRes.status}`);
      if (!liveRes.ok) throw new Error(`live HTTP ${liveRes.status}`);
      const stats = await statsRes.json();
      const live = await liveRes.json();
      renderToday(stats);
      renderLive(live);
      setStatus('ok', `ok · ${new Date().toLocaleTimeString()}`);
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      setStatus('error', `error: ${msg}`);
      const rawEl = $('raw-payload');
      if (rawEl.textContent === '—') {
        $('dist-versions').replaceChildren(errorState('Failed to load'));
        $('dist-os').replaceChildren(errorState('Failed to load'));
        $('dist-countries').replaceChildren(errorState('Failed to load'));
      }
    } finally {
      liveInFlight = false;
    }
  }

  function renderToday(data) {
    if (!data || typeof data !== 'object') return;

    $('kpi-date').textContent = data.date || '—';
    $('kpi-dau').textContent = formatNumber(data.daily_active_users);
    $('kpi-hb').textContent = formatNumber(data.total_heartbeats_today);
    $('kpi-uc').textContent = formatNumber(data.total_update_checks_today);
    $('kpi-installs').textContent = formatNumber(data.total_installations);
    $('last-updated').textContent = new Date().toLocaleString();

    renderDistribution('dist-versions', 'count-versions', data.version_distribution, (v) => ({
      label: `<span class="font-mono">v${escapeHtml(v)}</span>`,
      sub: '',
    }));
    renderDistribution('dist-os', 'count-os', data.os_distribution, (os) => ({
      label: `${osIcon(os)} ${escapeHtml(osLabel(os))}`,
      sub: '',
    }));
    renderDistribution('dist-countries', 'count-countries', data.country_distribution, (code) => ({
      label: `${countryFlag(code)} ${escapeHtml(COUNTRY_NAMES[code.toUpperCase()] || code)}`,
      sub: escapeHtml(code),
    }));

    $('raw-payload').textContent = JSON.stringify(data, null, 2);
  }

  function renderLive(data) {
    if (!data || typeof data !== 'object') {
      $('kpi-active-now').textContent = '—';
      return;
    }
    $('kpi-active-now').textContent = formatNumber(data.active_now ?? 0);
    if (typeof data.window_seconds === 'number') {
      $('kpi-active-window').textContent = String(Math.round(data.window_seconds / 60));
    }
    $('kpi-active-versions').textContent = formatNumber(distinctCount(data.by_version));
    $('kpi-active-os').textContent = formatNumber(distinctCount(data.by_os));
    $('kpi-active-countries').textContent = formatNumber(distinctCount(data.by_country));
  }

  // ── History fetch ──────────────────────────────────────────────────────────

  let historyInFlight = false;
  async function fetchHistory() {
    if (historyInFlight) return;
    historyInFlight = true;
    try {
      const [dauRes, hbRes, verRes] = await Promise.all([
        fetch(`${ENDPOINTS.history}?metric=dau&days=${HISTORY_DAYS}`, { cache: 'no-store' }),
        fetch(`${ENDPOINTS.history}?metric=heartbeats&days=${HISTORY_DAYS}`, { cache: 'no-store' }),
        fetch(`${ENDPOINTS.history}?metric=version&days=${HISTORY_DAYS}`, { cache: 'no-store' }),
      ]);
      const [dau, hb, ver] = await Promise.all([dauRes.json(), hbRes.json(), verRes.json()]);

      renderLineArea('chart-dau', dau.series ?? [], '#d97757', 'chart-dau-peak', 'chart-dau-from', 'chart-dau-to');
      renderLineArea('chart-hb', hb.series ?? [], '#60a5fa', 'chart-hb-peak', 'chart-hb-from', 'chart-hb-to');
      renderStackedArea('chart-versions', 'chart-versions-legend', 'chart-version-buckets', 'chart-versions-from', 'chart-versions-to', ver.series ?? []);
    } catch (err) {
      // Silent fail for history; live data continues to update. The empty-state
      // text inside each chart is replaced on a successful fetch.
      console.error('[stat] history fetch failed', err);
    } finally {
      historyInFlight = false;
    }
  }

  // ── Wire up ────────────────────────────────────────────────────────────────

  $('refresh-btn').addEventListener('click', () => {
    fetchLiveAndToday();
    fetchHistory();
  });

  fetchLiveAndToday();
  fetchHistory();

  const livePoll = setInterval(() => {
    if (document.visibilityState === 'visible') fetchLiveAndToday();
  }, LIVE_POLL_MS);
  const historyPoll = setInterval(() => {
    if (document.visibilityState === 'visible') fetchHistory();
  }, HISTORY_POLL_MS);

  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') {
      fetchLiveAndToday();
      fetchHistory();
    }
  });

  window.addEventListener('beforeunload', () => {
    clearInterval(livePoll);
    clearInterval(historyPoll);
  });
  </script>
</Layout>
