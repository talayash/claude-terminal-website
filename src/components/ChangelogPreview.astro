---
import changelog from '../data/changelog.json';
const recent = changelog.slice(0, 3);

// Normalize glyphs JetBrains Mono can't render (e.g. ⇕ U+21D5 → ↕ U+2195).
const clean = (s: string) => s.replace(/⇕/g, '↕').replace(/⇔/g, '↔');
---

<section class="clp">
  <div class="wrap">
    <div class="head reveal">
      <div class="gutter-label">[ 06 ] / changelog</div>
      <div class="head-row">
        <h2 class="display clp-h2">Shipping, constantly.</h2>
        <a class="all" href="/changelog">full history →</a>
      </div>
    </div>

    <div class="rel-grid reveal">
      {recent.map(rel => (
        <a class="rel glass glass-hover" href="/changelog">
          <div class="rel-top">
            <span class="rel-ver">v{rel.version}</span>
            <span class="rel-date">{rel.date}</span>
          </div>
          <ul class="rel-feats">
            {rel.features.slice(0, 3).map(f => (
              <li><span class="b">●</span>{clean(f.title)}</li>
            ))}
            {rel.features.length > 3 && <li class="more">+ {rel.features.length - 3} more</li>}
          </ul>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .clp { padding: 80px 16px; }
  .wrap { max-width: 1120px; margin: 0 auto; }
  .head { margin-bottom: 30px; }
  .gutter-label { margin-bottom: 16px; }
  .head-row { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .clp-h2 { font-size: clamp(26px, 4.5vw, 40px); margin: 0; }
  .all { font-size: 12px; color: #d97757; text-decoration: none; letter-spacing: 0.5px; }
  .all:hover { color: #e89878; }

  .rel-grid { display: grid; grid-template-columns: 1fr; gap: 14px; }
  .rel { border-radius: 14px; padding: 18px; text-decoration: none; display: block; }
  .rel-top { display: flex; align-items: baseline; gap: 10px; margin-bottom: 14px; }
  .rel-ver { font-size: 13px; color: #d97757; font-weight: 800; }
  .rel-date { font-size: 10.5px; color: #5f5f6b; letter-spacing: 1px; }
  .rel-feats { list-style: none; padding: 0; margin: 0; }
  .rel-feats li { font-size: 11.5px; color: #b0b0bc; line-height: 1.55; padding: 3px 0; display: flex; gap: 8px; }
  .rel-feats .b { color: #d97757; font-size: 8px; padding-top: 4px; flex-shrink: 0; }
  .rel-feats .more { color: #5f5f6b; padding-left: 16px; }

  @media (min-width: 820px) { .rel-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
