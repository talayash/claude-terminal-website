---
interface Props {
  version: string;
  stars?: number;
  commits?: number;
}
const { version, stars, commits } = Astro.props;

const items = [
  { k: stars ? `★ ${stars}` : '★ GitHub', v: 'open source' },
  { k: 'Windows + macOS', v: 'cross-platform' },
  { k: `v${version}`, v: 'actively shipped' },
  { k: 'MIT', v: 'free forever' },
  { k: 'Tauri + Rust', v: 'native & fast' },
];
---

<section class="trust">
  <div class="trust-inner">
    {items.map((it, i) => (
      <>
        <div class="ti">
          <span class="ti-k">{it.k}</span>
          <span class="ti-v">{it.v}</span>
        </div>
        {i < items.length - 1 && <span class="ti-sep">/</span>}
      </>
    ))}
  </div>
</section>

<style>
  .trust { border-top: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06); }
  .trust-inner {
    max-width: 1120px; margin: 0 auto; padding: 16px 16px;
    display: flex; align-items: center; justify-content: center; flex-wrap: wrap;
    gap: 10px 20px;
  }
  .ti { display: inline-flex; flex-direction: column; align-items: center; line-height: 1.3; }
  .ti-k { font-size: 12px; color: #e9e9f0; font-weight: 700; letter-spacing: 0.5px; }
  .ti-v { font-size: 9.5px; color: #5f5f6b; letter-spacing: 1.5px; text-transform: uppercase; }
  .ti-sep { color: rgba(255,255,255,0.12); font-size: 14px; }
  @media (max-width: 640px) { .ti-sep { display: none; } }
</style>
