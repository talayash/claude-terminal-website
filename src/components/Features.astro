---
const cells = [
  {
    cls: 'b-grid', span: 'hero', key: 'GRID',
    title: 'Smart Grid View',
    desc: 'See up to 8 Claude Code sessions at once with intelligent auto-layouts (1×1 → 2×4). Arrow-key navigation, color-coded tiles. Toggle with Ctrl+G.',
    img: '/screenshots/grid-view.png', alt: 'Grid view showing multiple Claude Code sessions',
  },
  {
    cls: 'b-multi', span: 'wide', key: 'MUX',
    title: 'Multi-Terminal Management',
    desc: 'Tabbed terminals with drag-and-drop reorder, custom nicknames, and color tags. Sessions persist across restarts.',
    img: '/screenshots/main-view.png', alt: 'Main tabbed terminal interface',
  },
  {
    cls: 'b-profiles', span: 'tall', key: 'CFG',
    title: 'Configuration Profiles',
    desc: 'Saved CLI flag sets (--model opus, --verbose), per-session env vars and working directories. Quick-launch any setup.',
    img: '/screenshots/profiles.png', alt: 'Configuration profiles panel',
  },
  {
    cls: 'b-hints', span: '', key: 'F1',
    title: 'Command Hints',
    desc: 'Searchable, categorized tips panel (F1) with one-click copy. Plus full keyboard shortcuts for power users.',
  },
  {
    cls: 'b-setup', span: '', key: 'INIT',
    title: 'Auto-Setup Wizard',
    desc: 'Detects Node.js & Claude Code, installs what’s missing — one click to a working environment.',
  },
  {
    cls: 'b-update', span: '', key: 'OTA',
    title: 'Auto-Updates',
    desc: 'Background download, one-click install. Never miss a release.',
  },
  {
    cls: 'b-teams', span: '', key: 'TEAM',
    title: 'Agent Teams Panel',
    desc: 'Monitor Claude Code multi-agent team sessions — live structure, members, and task tracking.',
  },
];
---

<section id="features" class="feat">
  <div class="wrap">
    <div class="head reveal">
      <div class="gutter-label">[ 02 ] / features</div>
      <h2 class="display feat-h2">Everything you need to run a <span class="acc">fleet</span>.</h2>
    </div>

    <div class="bento reveal">
      {cells.map(c => (
        <article class={`cell glass glass-hover ${c.cls}`}>
          <div class="cell-top">
            <span class="cell-key">{c.key}</span>
            <h3 class="cell-title">{c.title}</h3>
            <p class="cell-desc">{c.desc}</p>
          </div>
          {c.img && (
            <div class="cell-img">
              <img src={c.img} alt={c.alt} loading="lazy" decoding="async" />
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .feat { padding: 80px 16px; }
  .wrap { max-width: 1120px; margin: 0 auto; }
  .head { margin-bottom: 34px; }
  .gutter-label { margin-bottom: 16px; }
  .feat-h2 { font-size: clamp(28px, 5vw, 46px); margin: 0; }

  .bento { display: grid; grid-template-columns: 1fr; gap: 14px; }

  .cell { border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; min-height: 168px; }
  .cell-top { padding: 20px 20px 14px; }
  .cell-key { font-size: 9.5px; letter-spacing: 2.5px; color: #d97757; }
  .cell-title { font-size: 15px; color: #fff; font-weight: 700; margin: 9px 0 7px; letter-spacing: -0.2px; }
  .cell-desc { font-size: 12px; color: #9a9aa8; line-height: 1.6; }
  .cell-img { margin-top: auto; padding: 0 16px 16px; }
  .cell-img img { width: 100%; border-radius: 9px; border: 1px solid rgba(255,255,255,0.08); display: block; }

  @media (min-width: 760px) {
    .bento {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: minmax(150px, auto);
    }
    .b-grid   { grid-column: span 2; grid-row: span 2; }
    .b-multi  { grid-column: span 2; }
    .b-profiles { grid-column: span 1; grid-row: span 1; }
    .b-hints  { grid-column: span 1; }
    .b-setup  { grid-column: span 2; }
    .b-update { grid-column: span 1; }
    .b-teams  { grid-column: span 1; }
    .b-grid .cell-title { font-size: 18px; }
    .b-grid .cell-desc { font-size: 12.5px; }
  }
</style>
