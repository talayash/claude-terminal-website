---
const shots = [
  { src: '/screenshots/new-terminal.png', file: 'new-terminal', cls: 'wide',
    cap: 'Launch a session: pick a profile, set a nickname, working directory, and Claude arguments.' },
  { src: '/screenshots/settings.png', file: 'settings', cls: '',
    cap: 'Deep settings — appearance, behavior, and per-feature control.' },
  { src: '/screenshots/welcome.png', file: 'welcome', cls: '',
    cap: 'Guided first-run wizard gets you from install to running in minutes.' },
];
---

<section id="tour" class="tour">
  <div class="wrap">
    <div class="head reveal">
      <div class="gutter-label">[ 03 ] / tour</div>
      <h2 class="display tour-h2">A closer look.</h2>
    </div>

    <div class="tour-grid">
      {shots.map(s => (
        <figure class={`win ${s.cls} reveal`}>
          <div class="win-bar">
            <span class="win-dots"><span></span><span></span><span></span></span>
            <span>{s.file}.png</span>
          </div>
          <img src={s.src} alt={s.cap} loading="lazy" decoding="async" class="block w-full" />
          <figcaption>// {s.cap}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .tour { padding: 80px 16px; }
  .wrap { max-width: 1120px; margin: 0 auto; }
  .head { margin-bottom: 34px; }
  .gutter-label { margin-bottom: 16px; }
  .tour-h2 { font-size: clamp(26px, 4.5vw, 40px); margin: 0; }

  .tour-grid { display: grid; grid-template-columns: 1fr; gap: 18px; }
  .win img { display: block; }
  .win figcaption { padding: 12px 14px; font-size: 11px; color: #8a8a96; line-height: 1.55; border-top: 1px solid rgba(255,255,255,0.06); }

  @media (min-width: 820px) {
    .tour-grid { grid-template-columns: 1fr 1fr; }
    .win.wide { grid-column: span 2; }
  }
</style>
