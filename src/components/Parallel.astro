---
const beats = [
  { n: '01', t: 'The bottleneck moved', d: 'Agentic coding shifted the work from typing code to supervising agents. The hard part is no longer writing — it’s keeping track.' },
  { n: '02', t: 'Parallel is the norm', d: 'Real workflows run several Claude Code sessions at once, each isolated in its own branch or worktree so they don’t collide.' },
  { n: '03', t: 'Tabs don’t scale', d: 'Two is fine. Five buried in terminal tabs is cognitive overload — you lose the thread of who’s doing what.' },
];
---

<section class="why">
  <div class="wrap">
    <div class="why-text reveal">
      <div class="gutter-label">[ 01 ] / why</div>
      <h2 class="display why-h2">One operator.<br /><span class="acc">N</span> parallel sessions.</h2>
      <div class="beats">
        {beats.map(b => (
          <div class="beat">
            <span class="beat-n">{b.n}</span>
            <div>
              <div class="beat-t">{b.t}</div>
              <div class="beat-d">{b.d}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="why-vis reveal" aria-hidden="true">
      <svg viewBox="0 0 320 300" class="graph">
        <defs>
          <radialGradient id="op" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#e89878" />
            <stop offset="100%" stop-color="#d97757" />
          </radialGradient>
        </defs>
        <g class="edges" stroke="#d97757" stroke-width="1.2" fill="none" opacity="0.5">
          <line x1="160" y1="150" x2="60" y2="56" />
          <line x1="160" y1="150" x2="270" y2="70" />
          <line x1="160" y1="150" x2="44" y2="180" />
          <line x1="160" y1="150" x2="284" y2="186" />
          <line x1="160" y1="150" x2="100" y2="262" />
          <line x1="160" y1="150" x2="232" y2="258" />
        </g>
        <g class="sessions">
          <g class="node" style="--i:0"><circle cx="60" cy="56" r="7" /><text x="60" y="40">build</text></g>
          <g class="node" style="--i:1"><circle cx="270" cy="70" r="7" /><text x="270" y="54">tests</text></g>
          <g class="node" style="--i:2"><circle cx="44" cy="180" r="7" /><text x="44" y="204">review</text></g>
          <g class="node" style="--i:3"><circle cx="284" cy="186" r="7" /><text x="284" y="210">docs</text></g>
          <g class="node" style="--i:4"><circle cx="100" cy="262" r="7" /><text x="100" y="284">refactor</text></g>
          <g class="node" style="--i:5"><circle cx="232" cy="258" r="7" /><text x="232" y="280">deploy</text></g>
        </g>
        <circle cx="160" cy="150" r="15" fill="url(#op)" />
        <circle cx="160" cy="150" r="15" fill="none" stroke="#e89878" stroke-width="1" class="op-ring" />
        <text x="160" y="178" class="op-label">you</text>
      </svg>
    </div>
  </div>
</section>

<style>
  .why { padding: 80px 16px; }
  .wrap { max-width: 1120px; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 50px; align-items: center; }
  .gutter-label { margin-bottom: 18px; }
  .why-h2 { font-size: clamp(28px, 5vw, 44px); margin: 0 0 32px; }
  .beats { display: flex; flex-direction: column; gap: 22px; }
  .beat { display: grid; grid-template-columns: 34px 1fr; gap: 14px; align-items: start; }
  .beat-n { font-size: 11px; color: #d97757; letter-spacing: 1px; padding-top: 3px; }
  .beat-t { font-size: 13px; color: #fff; font-weight: 700; margin-bottom: 4px; }
  .beat-d { font-size: 12.5px; color: #9a9aa8; line-height: 1.65; }

  .why-vis { display: flex; justify-content: center; }
  .graph { width: 100%; max-width: 360px; }
  .graph text { font-family: "JetBrains Mono", monospace; font-size: 9px; fill: #8a8a96; text-anchor: middle; letter-spacing: 1px; }
  .op-label { fill: #1a0d07 !important; font-weight: 700; font-size: 8px; }
  .node circle { fill: #0b0b12; stroke: #d97757; stroke-width: 1.4; }
  .node { animation: nodepulse 3.2s ease-in-out infinite; animation-delay: calc(var(--i) * 0.4s); transform-box: fill-box; transform-origin: center; }
  .op-ring { animation: opring 3s ease-out infinite; transform-box: fill-box; transform-origin: center; }
  @keyframes nodepulse { 0%,100% { opacity: 0.55; } 50% { opacity: 1; } }
  @keyframes opring { 0% { r: 15; opacity: 0.8; } 100% { r: 30; opacity: 0; } }

  @media (min-width: 900px) {
    .wrap { grid-template-columns: 1.1fr 0.9fr; gap: 60px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .node, .op-ring { animation: none; }
    .node { opacity: 0.85; }
  }
</style>
