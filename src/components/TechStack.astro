---
const stack = ['tauri 2', 'rust', 'react 18', 'typescript', 'xterm.js', 'tailwind', 'zustand', 'sqlite'];
---

<section class="stack">
  <div class="line">
    <span class="lbl"><span class="acc">/</span> built with</span>
    {stack.map((t, i) => (
      <>
        <span class="t">{t}</span>
        {i < stack.length - 1 && <span class="sep">·</span>}
      </>
    ))}
  </div>
</section>

<style>
  .stack { border-top: 1px solid rgba(255,255,255,0.06); }
  .line { max-width: 1120px; margin: 0 auto; padding: 18px 16px;
    display: flex; align-items: center; gap: 12px; font-size: 11px; letter-spacing: 1.5px;
    color: #9a9aa8; overflow-x: auto; white-space: nowrap; }
  .lbl { color: #e9e9f0; font-weight: 700; }
  .lbl .acc { color: #d97757; }
  .t { color: #8a8a96; }
  .sep { color: rgba(255,255,255,0.16); }
  .line::-webkit-scrollbar { height: 3px; }
</style>
